PORT=5000
NODE_ENV=production
MONGODB_URI=mongodb://localhost:27017/cap_db

# MongoDB pool (shared hosting: 3–5)
MONGODB_MAX_POOL_SIZE=5
MONGODB_MAX_IDLE_MS=30000

JWT_SECRET=your_super_secret_jwt_key_change_in_production
JWT_EXPIRES_IN=7d
CLIENT_URL=https://your-domain.example

# Security & limits
TRUST_PROXY=true
RATE_LIMIT_MAX=300
AUTH_RATE_LIMIT_MAX=30
JSON_BODY_LIMIT=2mb
MAX_BACKGROUND_TASKS=2
# Response cache (in-memory, per user)
CACHE_MAX_ENTRIES=300
CACHE_DEFAULT_TTL_MS=60000
CACHE_TTL_ANALYTICS_MS=90000
CACHE_TTL_ROLES_MS=120000
CACHE_TTL_ASSESSMENTS_MS=120000
CACHE_TTL_QUESTIONS_MS=120000
CACHE_TTL_CANDIDATES_MS=45000
CACHE_TTL_RESPONSES_MS=30000
SHUTDOWN_TIMEOUT_MS=10000

RMS_API_KEY=rms_secret_key_change_in_production
GEMINI_API_KEY=your_gemini_api_key_here

# PM2 optional
# PM2_MAX_MEMORY=400M
