{
  "name": "cap-backend",
  "version": "1.0.0",
  "description": "Candidate Assessment Portal - Backend",
  "main": "server.js",
  "scripts": {
    "start": "NODE_ENV=production node server.js",
    "start:win": "set NODE_ENV=production&& node server.js",
    "dev": "nodemon server.js",
    "seed": "node src/seed/index.js",
    "build": "cd ../frontend && npm install && npm run build",
    "build:prod": "cd ../frontend && npm ci && npm run build"
  },
  "dependencies": {
    "@google/generative-ai": "^0.24.1",
    "bcryptjs": "^2.4.3",
    "compression": "^1.8.1",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.19.2",
    "express-rate-limit": "^7.3.1",
    "helmet": "^7.1.0",
    "jsonwebtoken": "^9.0.2",
    "mammoth": "^1.12.0",
    "mongoose": "^8.4.1",
    "morgan": "^1.10.0",
    "multer": "^2.1.1",
    "nanoid": "^3.3.7",
    "pdf-parse": "^1.1.1"
  },
  "devDependencies": {
    "nodemon": "^3.1.3"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
