# ─── Portal SSO Integration ───────────────────────────────────────────────────
# Shared secret — must match SSO_SECRET in Portal Launcher .env exactly
# Generate with: openssl rand -base64 48
SSO_SECRET=do-not-change-me-use-openssl-rand-base64-48-for-sso-launch-tokens
# Application code the Portal encodes in the launch token's `application` claim
SSO_APPLICATION_CODE=ASSESSMENT
SSO_APP_EMAIL_MAP=admin@bylinelms.com:admin@byline.com,newadmin@portal.io:admin@byline.com
# Optional: enforce issuer claim validation (set to match Portal's SSO_ISSUER)
# SSO_ISSUER=sso-portal
# Frontend URL used for redirect after SSO callback
FRONTEND_URL=http://localhost:5176,https://assessment-portal.legatolxp.online

# ✅ FIX: was NODE_ENV=production which caused the catch-all to not serve React in dev
NODE_ENV=development

# Gemini API Key for resume parsing
GEMINI_API_KEY=AIzaSyCBYvhVMwEgAF4N_7OQ_NoERs8lTOnlhng

# ─── RMS → CAP Integration ───────────────────────────────────────────────────
# Shared API key — must match RMS_API_KEY in RMS .env exactly
RMS_API_KEY=rms_secret_key_change_in_production

# Shared webhook secret — must match ASSESSMENT_PORTAL_WEBHOOK_SECRET in RMS .env
ASSESSMENT_PORTAL_WEBHOOK_SECRET=webhook_secret_change_me

# ✅ FIX: was http://localhost:3001 (missing /api path)
# LOCAL:
# RMS_API_BASE_URL=http://localhost:3001/api
# PRODUCTION (uncomment when deploying):
RMS_API_BASE_URL=https://hr.legatolxp.online/api